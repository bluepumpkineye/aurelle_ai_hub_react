# OpenAI API Configuration (PRIMARY provider)
OPENAI_API_KEY=

# xAI API Configuration (FALLBACK provider — used automatically if OpenAI fails)
XAI_API_KEY=

# ── LLM routing (optional overrides) ──
# Aurelle routes all traffic to PRIMARY_MODEL and transparently fails over to
# FALLBACK_MODEL on any error/timeout/missing-key. No manual model selection.
PRIMARY_MODEL=o3-2025-04-16
FALLBACK_MODEL=grok-4.3
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
REASONING_MIN_TOKENS=2500    # token floor for o-series reasoning models

# Salt for hashing offline mock-user passwords (demo auth only)
MOCK_AUTH_SALT=aurelle-apac-demo

# Supabase Auth Configuration
# NOTE: never commit real values here. Use a local .env (gitignored) or, in
# production, the platform secret store (Hugging Face Space secrets / CI secrets).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── Admin / demo auth ──
# Override the built-in demo admin. ADMIN_PASSWORD_HASH is a PBKDF2-SHA256 hash
# (generate with:  python -m utils.auth --hash 'your-password').
ADMIN_EMAIL=admin@aurelle.com
ADMIN_PASSWORD_HASH=

# ── Security tuning (optional) ──
SESSION_IDLE_TIMEOUT_MIN=60      # auto sign-out after inactivity
LLM_RATE_LIMIT_PER_MIN=15        # max AI generations per session per minute
MAX_INPUT_CHARS=4000             # cap on user-supplied prompt length
LOGIN_MAX_ATTEMPTS=5             # lockout threshold per session

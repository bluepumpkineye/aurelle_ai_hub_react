</node>
<node id="Emergency Stock Request (ESR)">
  <data key="d0">Emergency Stock Request (ESR)</data>
  <data key="d1">method</data>
  <data key="d2">The Emergency Stock Request is a protocol for boutique directors to request urgent stock from Switzerland when specific conditions are met.</data>
  <data key="d3">chunk-35512f32ea45c1b275bccd44a565ae39</data>
  <data key="d4">unknown_source</data>

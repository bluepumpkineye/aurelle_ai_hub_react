<graph edgedefault="undirected"><node id="Aurelle APAC">
  <data key="d0">Aurelle APAC</data>
  <data key="d1">organization</data>
  <data key="d2">Aurelle APAC operates a dual-hub supply chain model across 13 markets and 67 boutique/sales points, focusing on speed-to-market and inventory health.&lt;SEP&gt;Aurelle APAC is a company that provides after-sales service and repair operations, focusing on client retention and brand equity.&lt;SEP&gt;Aurelle APAC is the organization responsible for the Learning &amp; Development Framework, specifically the Client Advisor Excellence Program (CAEP).&lt;SEP&gt;Aurelle APAC is an organization responsible for budget planning, revenue reporting, and financial governance across its markets in the Asia-Pacific region.&lt;SEP&gt;Aurelle APAC is a company that operates a unified CRM and digital engagement stack, focusing on global brand consistency and regional digital infrastructure.</data>
  <data key="d3">chunk-35512f32ea45c1b275bccd44a565ae39&lt;SEP&gt;chunk-bd66dc6d321e6ab40161890d1bc0bc2c&lt;SEP&gt;chunk-865d7129bc86ace31cbe4375e94be48d&lt;SEP&gt;chunk-9bf9f4d3ad12fec2767f4aa8c9646beb&lt;SEP&gt;chunk-75d42a367a62c88ae3e50dd63478fd49</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779675924</data>
  <data key="d6"></data>
</node>
<node id="Singapore Distribution Centre (SDC)">
  <data key="d0">Singapore Distribution Centre (SDC)</data>
  <data key="d1">location</data>
  <data key="d2">The Singapore Distribution Centre is the primary hub for Southeast Asia, with a warehousing capacity of 12,000 units and an average transit time of 3–5 business days.</data>
  <data key="d3">chunk-35512f32ea45c1b275bccd44a565ae39</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779675586</data>
  <data key="d6"></data>
</node>
<node id="Switzerland Direct (ZHD)">
  <data key="d0">Switzerland Direct (ZHD)</data>
  <data key="d1">location</data>
  <data key="d2">Switzerland Direct supplies North Asia directly from Manufacture in Le Brassus/Geneva, utilizing Swiss Air Freight for lower transit times.</data>
  <data key="d3">chunk-35512f32ea45c1b275bccd44a565ae39</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779675586</data>
  <data key="d6"></data>
</node>
<node id="India Supply Corridor">
  <data key="d0">India Supply Corridor</data>
  <data key="d1">location</data>
  <data key="d2">The India Supply Corridor supplies India from the Singapore Distribution Centre, with customs clearance handled in Mumbai.</data>
  <data key="d3">chunk-35512f32ea45c1b275bccd44a565ae39</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779675586</data>
  <data key="d6"></data>
</node>
<node id="Regional Supply Chain VP">
  <data key="d0">Regional Supply Chain VP</data>
  <data key="d1">person</data>
  <data key="d2">The Regional Supply Chain VP negotiates the APAC quota with HQ in Geneva for the following year.</data>
  <data key="d3">chunk-35512f32ea45c1b275bccd44a565ae39</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779675586</data>
  <data key="d6"></data>
</node>
<node id="Aurelle Master Inventory System">
  <data key="d0">Aurelle Master Inventory System</data>
  <data key="d1">system</data>
  <data key="d2">The Aurelle Master Inventory System tracks unique piece numbers for high jewellery, ensuring no duplication or substitution.</data>
  <data key="d3">chunk-35512f32ea45c1b275bccd44a565ae39</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779675586</data>
  <data key="d6"></data>
</node>
<node id="Allocation Optimizer">
  <data key="d0">Allocation Optimizer</data>
  <data key="d1">system</data>
  <data key="d2">The Allocation Optimizer engine applies weighted criteria to manage limited stock of high-demand references across boutiques.</data>
  <data key="d3">chunk-35512f32ea45c1b275bccd44a565ae39</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779675586</data>

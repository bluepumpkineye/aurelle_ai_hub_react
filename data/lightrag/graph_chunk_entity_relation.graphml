<node id="Market Director">
  <data key="d0">Market Director</data>
  <data key="d1">person</data>
  <data key="d2">The Market Director is responsible for making personal phone calls to Tier 1 Icon invitees before sending written invitations.&lt;SEP&gt;The Market Director is responsible for overseeing market strategies and is notified for personalized outreach when a customer is at high risk of churn.&lt;SEP&gt;The Market Director is responsible for overseeing client relationships and approving budgets within the Aurelle framework.</data>
  <data key="d3">chunk-02eefa7f22ecbf190aa8b142a4701ff0&lt;SEP&gt;chunk-2ab57f33730277bda03644a62ff087b1&lt;SEP&gt;chunk-fded559bb9aca0f811af2eda90f8e432</data>
